<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="#20274a"
    android:layout_height="match_parent">

    <!-- Lottie ocupando toda a parte superior -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimationView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/textView"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:background="#20274a"
        app:lottie_rawRes="@raw/ic_person_lottie" />

    <!-- Texto centralizado -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="10dp"
        android:text="GamePocket"
        android:textAlignment="center"
        android:textSize="42sp"
        android:textColor="@color/gray_light"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/lottieAnimationView"
        app:layout_constraintBottom_toTopOf="@id/lottieAnimationView3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lottie pequena no centro -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimationView3"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintBottom_toTopOf="@id/lottieAnimationView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="5dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:background="#20274a"
        app:lottie_rawRes="@raw/ic_loading" />

    <!-- Lottie ocupando toda a parte inferior -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimationView2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/lottieAnimationView3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:background="#20274a"
        app:lottie_rawRes="@raw/ic_flower_lottie" />

</androidx.constraintlayout.widget.ConstraintLayout>
