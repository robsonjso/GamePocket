<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    xmlns:app="http://schemas.android.com/apk/res-auto">



    
    <ImageView
        android:id="@+id/fotodoJogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/gta_6"
        android:layout_marginTop="84dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    
    <TextView
        android:id="@+id/nomedoJogo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grand Theft Auto VI"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginStart="140dp"
        android:layout_marginTop="84dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintStart_toEndOf="@id/fotodoJogo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/descricaodoJogo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="140dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:maxLines="4"
        android:textColor=" #D3D3D3"
        android:text="GTA 6 terá dois protagonistas, Lucia e Jason, um casal de criminosos à la Bonnie e Clyde."
        app:layout_constraintTop_toBottomOf="@id/nomedoJogo"
        app:layout_constraintStart_toEndOf="@id/fotodoJogo"
        app:layout_constraintEnd_toEndOf="parent"/>


    
    <ImageView
        android:id="@+id/fotodoJogo2"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="240dp"
        android:layout_marginHorizontal="16dp"
        android:src="@drawable/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>








</androidx.constraintlayout.widget.ConstraintLayout>