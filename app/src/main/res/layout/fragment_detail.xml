<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".core.ui.detail.DetailFragment">

    <ImageView
        android:id="@+id/gameImage"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/bg_capa_detail" />

    <TextView
        android:id="@+id/gameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="140dp"
        android:layout_marginTop="200dp"
        tools:text="Cuphead"
        android:textSize="30dp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/gameDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="290dp"
        android:justificationMode="inter_word"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:textStyle="bold"
        tools:text="Cuphead é um jogo eletrônico de run and gun criado pelos irmãos. O jogo foi inspirado no estilo de animação Rubber hose usado em desenhos animados da Era de Ouro da animação americana." />

    <ImageView
        android:id="@+id/gameIcon"
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:layout_marginTop="150dp"
        android:layout_marginStart="30dp"
        android:background="@drawable/bg_icon_detail">
    </ImageView>

    <ImageView
        android:id="@+id/gameFavorite"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="#FF0000"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="220dp">
    </ImageView>

    <ImageView
        android:id="@+id/gameStar"
        android:layout_width="70dp"
        android:layout_height="25dp"
        android:background="#FFFF00"
        android:layout_gravity="end"
        android:layout_marginEnd="200dp"
        android:layout_marginTop="250dp">
    </ImageView>

    <ImageView
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_icon_detail"
        android:layout_marginStart="16dp"
        android:layout_marginTop="540dp">
    </ImageView>

    <ImageView
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_icon_detail"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="410dp">
    </ImageView>

    <ImageView
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_icon_detail"
        android:layout_marginStart="16dp"
        android:layout_marginTop="410dp">
    </ImageView>

    <ImageView
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_icon_detail"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="410dp">
    </ImageView>

    <ImageView
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_icon_detail"
        android:layout_marginEnd="16dp"
        android:layout_gravity="end"
        android:layout_marginTop="540dp">
    </ImageView>

    <ImageView
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_icon_detail"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="540dp">
    </ImageView>

    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_marginStart="16dp"
        android:text="Return" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Imagens do jogo:"
        android:layout_marginTop="370dp"
        android:layout_marginStart="16dp"
        android:textStyle="italic"/>

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
